{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — least-privilege",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://accounts.google.com/*"
        },
        {
          "url": "https://login.microsoftonline.com/*"
        }
      ]
    },
    "dialog:allow-open"
  ]
}